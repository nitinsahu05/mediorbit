# MongoDB Atlas connection string
# Replace <username>, <password>, and <cluster-url> with your Atlas details
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-url>/appointy?retryWrites=true&w=majority"

# JWT signing secret used for user and admin tokens
JWT_SECRET="your_jwt_secret_here"

# Admin dashboard login credentials
ADMIN_EMAIL="your_admin_email@example.com"
ADMIN_PASSWORD="your_admin_password"
